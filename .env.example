# Copy this file to .env and fill in your values

# ===========================================
# SLACK CREDENTIALS (Required for Socket Mode)
# ===========================================

# Slack Bot Token (xoxb-...) from OAuth & Permissions page
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# Slack App Token (xapp-...) for Socket Mode
# Generate at: Basic Information > App-Level Tokens > Generate Token
# Required scope: connections:write
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Signing Secret from Basic Information > App Credentials
SLACK_SIGNING_SECRET=your-signing-secret

# Bot User ID (U...) - find in Slack app settings under "App Home"
# Used to filter out bot's own messages and detect @mentions
BOT_USER_ID=UXXXXXXXX

# ===========================================
# DM ACCESS CONTROL (Optional)
# ===========================================

# Set to "true" to enable DM restriction (default: false)
# DM_RESTRICTION_ENABLED=true

# Comma-separated list of Slack user IDs allowed to DM the bot
# Only used when DM_RESTRICTION_ENABLED=true
# Example: ALLOWED_DM_USERS=U6GJSMG20,U0A7Y6NAHK6
# ALLOWED_DM_USERS=